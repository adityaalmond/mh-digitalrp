{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Real estate project details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "area": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["name", "area", "type"]
    },
    "Team": {
      "title": "Team",
      "description": "Sales teams/divisions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "gdkd": { "type": "string", "description": "Director name" }
      },
      "required": ["name", "code", "gdkd"]
    },
    "Line": {
      "title": "Line",
      "description": "Specific marketing/working line",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "leaderId": { "type": "string" },
        "memberIds": { "type": "array" }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "lineId": { "type": "string" },
        "teamId": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "Marketing implementation task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "projectId": { "type": "string" },
        "budget": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "saleInCharge": { "type": "string" },
        "assignmentType": { "type": "string", "enum": ["company", "sales_dept"] },
        "assignedLineId": { "type": "string" },
        "assignedStaffIds": { "type": "array" }
      },
      "required": ["title", "projectId", "budget", "startDate", "endDate", "assignedLineId"]
    },
    "DailyReport": {
      "title": "Daily Report",
      "description": "Metrics reported daily per task and staff",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "taskId": { "type": "string" },
        "staffId": { "type": "string" },
        "channel": { "type": "string", "enum": ["Facebook Ads", "Google Ads", "Zalo Ads", "Other"] },
        "spend": { "type": "number" },
        "leadsReceived": { "type": "number" },
        "leadsNotInterested": { "type": "number" },
        "leadsNurturing": { "type": "number" },
        "leadsInterested": { "type": "number" },
        "siteVisits": { "type": "number" },
        "closedDeals": { "type": "number" }
      },
      "required": ["date", "taskId", "staffId", "channel", "spend"]
    }
  },
  "firestore": {
    "/projects/{projectId}": { "schema": "Project", "description": "Collection of projects" },
    "/teams/{teamId}": { "schema": "Team", "description": "Collection of sales teams" },
    "/lines/{lineId}": { "schema": "Line", "description": "Collection of working lines" },
    "/users/{userId}": { "schema": "User", "description": "Collection of user profiles" },
    "/tasks/{taskId}": { "schema": "Task", "description": "Collection of marketing tasks" },
    "/dailyReports/{reportId}": { "schema": "DailyReport", "description": "Collection of daily metrics reports" }
  }
}
